<%
  /*
   * views/index.ejs
   * Main collection overview: filterable grid of all media items.
   */
  const pageTitle = 'Sammlung';
%>
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %> – MediaDock</title>
  <link rel="stylesheet" href="<%= base %>/public/style.css" />
</head>
<body>
  <header class="site-header">
    <a class="logo" href="<%= base %>/">
      <span class="logo-icon">🎵</span>
      <span class="logo-text">MediaDock</span>
    </a>
    <nav>
      <a href="<%= base %>/">Sammlung</a>
      <a href="<%= base %>/items/add" class="btn btn-primary">+ Hinzufügen</a>
    </nav>
  </header>

  <main class="container">
    <h1 class="page-title">Meine Sammlung</h1>

    <!-- ── Filter bar ──────────────────────────────────────────────────── -->
    <form class="filter-bar" method="get" action="<%= base %>/">
      <div class="filter-group">
        <label for="type">Typ</label>
        <select id="type" name="type" onchange="this.form.submit()">
          <option value="all" <%= selectedType === 'all' ? 'selected' : '' %>>Alle</option>
          <% for (const t of mediaTypes) { %>
            <option value="<%= t %>" <%= selectedType === t ? 'selected' : '' %>><%= t.charAt(0).toUpperCase() + t.slice(1) %></option>
          <% } %>
        </select>
      </div>

      <div class="filter-group">
        <label for="status">Status</label>
        <select id="status" name="status" onchange="this.form.submit()">
          <option value="all"      <%= selectedStatus === 'all'      ? 'selected' : '' %>>Alle</option>
          <option value="owned"    <%= selectedStatus === 'owned'    ? 'selected' : '' %>>Besitze ich</option>
          <option value="wishlist" <%= selectedStatus === 'wishlist' ? 'selected' : '' %>>Wunschliste</option>
        </select>
      </div>

      <span class="filter-count"><%= items.length %> Einträge</span>
    </form>

    <!-- ── Item grid ───────────────────────────────────────────────────── -->
    <% if (items.length === 0) { %>
      <div class="empty-state">
        <p>Noch keine Einträge. <a href="<%= base %>/items/add">Jetzt hinzufügen &rsaquo;</a></p>
      </div>
    <% } else { %>
      <ul class="item-grid">
        <% for (const item of items) { %>
          <li class="item-card">
            <a href="<%= base %>/items/<%= item.id %>" class="item-link">
              <div class="item-cover">
                <% if (item.cover_url) { %>
                  <img src="<%= item.cover_url %>" alt="<%= item.title %>" loading="lazy" />
                <% } else { %>
                  <div class="cover-placeholder"><span><%= item.media_type.toUpperCase() %></span></div>
                <% } %>
              </div>
              <div class="item-info">
                <p class="item-title"><%= item.title %></p>
                <% if (item.artist) { %><p class="item-artist"><%= item.artist %></p><% } %>
                <p class="item-meta">
                  <span class="badge badge-type"><%= item.media_type %></span>
                  <% if (item.year) { %><span class="item-year"><%= item.year %></span><% } %>
                  <% if (item.owned)    { %><span class="badge badge-owned">✔ Besitze ich</span><% } %>
                  <% if (item.wishlist) { %><span class="badge badge-wish">♥ Wunschliste</span><% } %>
                </p>
              </div>
            </a>
          </li>
        <% } %>
      </ul>
    <% } %>
  </main>

  <footer class="site-footer">
    <small>MediaDock &mdash; persönliche Mediensammlung</small>
  </footer>
</body>
</html>
