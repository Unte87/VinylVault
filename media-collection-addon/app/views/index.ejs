<%
  /*
   * views/index.ejs
   * Main collection overview: filterable/searchable/sortable grid of all media items.
   */
  const pageTitle = 'Sammlung';
%>
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %> – MediaDock</title>
  <link rel="stylesheet" href="<%= base %>/public/style.css" />
</head>
<body>
  <header class="site-header">
    <a class="logo" href="<%= base %>/">
      <span class="logo-icon">🎵</span>
      <span class="logo-text">MediaDock</span>
    </a>
    <div class="nav-wrap">
      <nav class="nav-primary">
        <a class="btn btn-ghost nav-link-collection" href="<%= base %>/"><span class="btn-icon"><svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2" /><circle cx="12" cy="12" r="2" fill="currentColor" /></svg></span><span class="btn-label">Sammlung</span></a>
        <a class="nav-link-desktop" href="<%= base %>/csv">CSV-Import</a>
        <a class="nav-link-desktop" href="<%= base %>/items/bulk-refresh">Massenanalyse</a>
        <a href="<%= base %>/items/wishlist-add" class="btn btn-secondary"><span class="btn-icon">♥</span><span class="btn-label">Wunschliste</span></a>
        <a href="<%= base %>/items/add" class="btn btn-primary"><span class="btn-icon">+</span><span class="btn-label">Hinzufügen</span></a>
      </nav>
      <details class="nav-more">
        <summary class="nav-more-btn" aria-label="Menue">Menu</summary>
        <div class="nav-more-panel">
          <a href="<%= base %>/csv">CSV-Import</a>
          <a href="<%= base %>/csv/export">CSV-Export</a>
          <a href="<%= base %>/items/bulk-refresh">Massenanalyse</a>
        </div>
      </details>
    </div>
  </header>

  <main class="container">
    <h1 class="page-title">Meine Sammlung</h1>

    <!-- ── Toolbar ────────────────────────────────────────────────────────── -->
    <div class="toolbar">

      <!-- Suche -->
      <div class="toolbar-search">
        <span class="toolbar-search-icon">🔍</span>
        <input
          id="search-input"
          type="search"
          placeholder="Titel oder Künstler…"
          autocomplete="off"
          spellcheck="false"
        />
      </div>

      <!-- Status-Filter -->
      <div class="filter-group">
        <label for="status">Status</label>
        <select id="status-filter">
          <option value="all"      <%= selectedStatus === 'all'      ? 'selected' : '' %>>Alle</option>
          <option value="owned"    <%= selectedStatus === 'owned'    ? 'selected' : '' %>>Besitze ich</option>
          <option value="wishlist" <%= selectedStatus === 'wishlist' ? 'selected' : '' %>>Wunschliste</option>
        </select>
      </div>

      <!-- Sortierung -->
      <div class="filter-group">
        <label for="sort-select">Sortierung</label>
        <select id="sort-select">
          <option value="added-desc">Zuletzt hinzugefügt</option>
          <option value="title-asc">Titel A–Z</option>
          <option value="title-desc">Titel Z–A</option>
          <option value="artist-asc">Künstler A–Z</option>
          <option value="year-asc">Jahr ↑</option>
          <option value="year-desc">Jahr ↓</option>
          <option value="rating-desc">Bewertung ↓</option>
        </select>
      </div>

      <!-- Ansicht + Zähler -->
      <div class="toolbar-right">
        <span class="filter-count" id="item-count"><%= items.length %> Platten</span>
        <div class="view-toggle" role="group" aria-label="Ansicht">
          <button class="view-btn active" id="view-grid"    title="Raster">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
              <rect x="0" y="0" width="6" height="6" rx="1"/><rect x="10" y="0" width="6" height="6" rx="1"/>
              <rect x="0" y="10" width="6" height="6" rx="1"/><rect x="10" y="10" width="6" height="6" rx="1"/>
            </svg>
          </button>
          <button class="view-btn" id="view-list"    title="Liste">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
              <rect x="0" y="1" width="16" height="3" rx="1"/><rect x="0" y="7" width="16" height="3" rx="1"/>
              <rect x="0" y="13" width="16" height="3" rx="1"/>
            </svg>
          </button>
          <button class="view-btn" id="view-carousel" title="Karussell">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
              <rect x="0" y="2" width="5" height="12" rx="1.5"/>
              <rect x="6" y="0" width="4" height="16" rx="1.5"/>
              <rect x="11" y="2" width="5" height="12" rx="1.5"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- ── Item list / grid ───────────────────────────────────────────────── -->
    <% if (items.length === 0) { %>
      <div class="empty-state">
        <p>Noch keine Einträge. <a href="<%= base %>/items/add">Jetzt hinzufügen &rsaquo;</a></p>
      </div>
    <% } else { %>
      <div class="select-mode-toggle">
        <button type="button" class="btn btn-ghost btn-sm" id="btn-toggle-select">☐ Mehrere auswählen</button>
      </div>
      <div id="no-results" class="empty-state" style="display:none">
        <p>Keine Ergebnisse für diese Suche.</p>
      </div>
      <div class="carousel-wrap" id="carousel-wrap">
        <button class="carousel-arrow carousel-arrow--prev" id="carousel-prev" aria-label="Zurück">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor"><path d="M12.5 4L7 10l5.5 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
        </button>
        <ul class="item-grid" id="item-grid">
        <% for (const item of items) { %>
          <li class="item-card"
              data-id="<%= item.id %>"
              data-title="<%= (item.title  || '').toLowerCase() %>"
              data-artist="<%= (item.artist || '').toLowerCase() %>"
              data-artist-name="<%= (item.artist || '').replace(/"/g, '&quot;') %>"
              data-year="<%= item.year  || '0' %>"
              data-rating="<%= item.rating || 0 %>"
              data-status="<%= item.owned ? 'owned' : item.wishlist ? 'wishlist' : 'none' %>"
              data-added="<%= item.id %>">
            <label class="item-checkbox-wrap" aria-label="Auswählen">
              <input type="checkbox" class="item-checkbox" value="<%= item.id %>" tabindex="-1" />
              <span class="item-checkbox-box">✔</span>
            </label>
            <a href="<%= base %>/items/<%= item.id %>" class="item-link">
              <div class="item-cover">
                <% if (item.cover_url) { %>
                  <img src="<%= item.cover_url %>" alt="<%= item.title %>" loading="lazy" />
                <% } else { %>
                  <div class="cover-placeholder"><span>🎵</span></div>
                <% } %>
              </div>
              <div class="item-info">
                <p class="item-title"><%= item.title %></p>
                <% if (item.artist) { %><p class="item-artist"><%= item.artist %></p><% } %>
                <p class="item-meta">
                  <% if (item.year) { %><span class="item-year"><%= item.year %></span><% } %>
                  <% if (item.owned)    { %><span class="badge badge-owned">✔ Besitze ich</span><% } %>
                  <% if (item.wishlist) { %><span class="badge badge-wish">♥ Wunschliste</span><% } %>
                </p>
              </div>
            </a>
            <div class="card-stars-interactive" data-id="<%= item.id %>" data-rating="<%= item.rating || 0 %>">
              <% for (let i = 1; i <= 5; i++) { %><span class="cstar <%= i <= (item.rating || 0) ? 'cstar-on' : 'cstar-off' %>" data-value="<%= i %>">★</span><% } %>
            </div>
            <% if (item.wishlist) { %>
              <a
                class="gh-link shop-link shop-link--gh"
                href="https://greenhell.de/search/?qs=<%= encodeURIComponent((item.artist ? item.artist + ' ' : '') + item.title).replace(/%20/g, '+') %>"
                target="_blank"
                rel="noopener"
                title="Bei Green Hell Records suchen"
              >Bei&nbsp;Green&nbsp;Hell&nbsp;suchen ↗</a>
              <a
                class="gh-link shop-link shop-link--amazon"
                href="https://www.amazon.de/s?k=<%= encodeURIComponent((item.artist ? item.artist + ' ' : '') + item.title) %>"
                target="_blank"
                rel="noopener"
                title="Bei Amazon suchen"
              >Bei&nbsp;Amazon&nbsp;suchen ↗</a>
            <% } %>
          </li>
        <% } %>
        </ul>
        <button class="carousel-arrow carousel-arrow--next" id="carousel-next" aria-label="Weiter">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor"><path d="M7.5 4L13 10l-5.5 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
        </button>
      </div>
    <% } %>

    <!-- Hidden bulk-delete form -->
    <form id="bulk-delete-form" method="post" action="<%= base %>/items/bulk-delete" style="display:none"></form>
  </main>

  <!-- ── Sticky Bulk-Action-Bar ─────────────────────────────────────────────── -->
  <div class="bulk-action-bar" id="bulk-action-bar">
    <span class="bulk-count" id="bulk-count">0 ausgewählt</span>
    <div class="bulk-actions">
      <button type="button" class="btn btn-ghost btn-sm" id="bulk-btn-all">Alle auswählen</button>
      <button type="button" class="btn btn-ghost btn-sm" id="bulk-btn-none">Aufheben</button>
      <button type="button" class="btn btn-danger btn-sm" id="bulk-btn-delete">Löschen</button>
    </div>
  </div>

  <footer class="site-footer">
    <small>MediaDock &mdash; persönliche Mediensammlung</small>
  </footer>

  <script>
    const BASE      = '<%= base %>';
    const grid      = document.getElementById('item-grid');
    const bulkBar   = document.getElementById('bulk-action-bar');
    const bulkCount = document.getElementById('bulk-count');
    const btnToggle = document.getElementById('btn-toggle-select');
    const noResults = document.getElementById('no-results');
    const countEl   = document.getElementById('item-count');
    let selectMode  = false;

    // ── Ansicht ────────────────────────────────────────────────────────────
    const VIEWS = ['grid', 'list', 'carousel'];
    let currentView = localStorage.getItem('md-view') || 'grid';

    function applyView(v) {
      currentView = v;
      localStorage.setItem('md-view', v);
      VIEWS.forEach(name => {
        grid?.classList.toggle('view-' + name, name === v);
        document.getElementById('view-' + name)?.classList.toggle('active', name === v);
      });
      const wrap = document.getElementById('carousel-wrap');
      wrap?.classList.toggle('is-carousel', v === 'carousel');
      if (v === 'carousel') initCarousel();
      applyFiltersAndSort();
    }

    VIEWS.forEach(v => document.getElementById('view-' + v)?.addEventListener('click', () => applyView(v)));

    // ── Coverflow-Karussell ────────────────────────────────────────────────
    function visibleCards() {
      return grid ? [...grid.querySelectorAll('.item-card')].filter(c => c.style.display !== 'none') : [];
    }

    function scrollToCard(card) {
      // Karte mittig im Scroll-Container positionieren
      const containerCenter = grid.getBoundingClientRect().left + grid.offsetWidth / 2;
      const cardCenter      = card.getBoundingClientRect().left + card.offsetWidth / 2;
      grid.scrollBy({ left: cardCenter - containerCenter, behavior: 'smooth' });
    }

    function getActiveCard() {
      // Karte die am nächsten zur Mitte des Containers ist
      const cards = visibleCards();
      if (!cards.length) return null;
      const containerCenter = grid.getBoundingClientRect().left + grid.offsetWidth / 2;
      let best = cards[0], bestDist = Infinity;
      cards.forEach(c => {
        const dist = Math.abs(c.getBoundingClientRect().left + c.offsetWidth / 2 - containerCenter);
        if (dist < bestDist) { bestDist = dist; best = c; }
      });
      return best;
    }

    function updateActiveCard() {
      const active = getActiveCard();
      visibleCards().forEach(c => c.classList.toggle('carousel-active', c === active));
    }

    function initCarousel() {
      updateActiveCard();
      grid.addEventListener('scroll', () => {
        clearTimeout(grid._scrollTimer);
        grid._scrollTimer = setTimeout(updateActiveCard, 60);
      }, { passive: true });
    }

    document.getElementById('carousel-prev')?.addEventListener('click', () => {
      const cards  = visibleCards();
      const active = getActiveCard();
      const idx    = cards.indexOf(active);
      // Zyklisch: springe zum Ende wenn am Anfang
      const target = cards[idx <= 0 ? cards.length - 1 : idx - 1];
      if (target) scrollToCard(target);
    });
    document.getElementById('carousel-next')?.addEventListener('click', () => {
      const cards  = visibleCards();
      const active = getActiveCard();
      const idx    = cards.indexOf(active);
      // Zyklisch: springe zum Anfang wenn am Ende
      const target = cards[idx >= cards.length - 1 ? 0 : idx + 1];
      if (target) scrollToCard(target);
    });
    // Nicht-aktive Karten im Carousel: Klick scrollt zu ihnen
    document.getElementById('item-grid')?.addEventListener('click', e => {
      if (currentView !== 'carousel') return;
      const card = e.target.closest('.item-card');
      if (!card || card.classList.contains('carousel-active')) return;
      e.preventDefault();
      scrollToCard(card);
    });
    // Pfeiltasten
    document.addEventListener('keydown', e => {
      if (currentView !== 'carousel') return;
      if (e.key === 'ArrowLeft')  document.getElementById('carousel-prev')?.click();
      if (e.key === 'ArrowRight') document.getElementById('carousel-next')?.click();
    });

    // ── Suche + Filter + Sortierung ────────────────────────────────────────
    const searchInput  = document.getElementById('search-input');
    const statusFilter = document.getElementById('status-filter');
    const sortSelect   = document.getElementById('sort-select');

    // Gespeicherte Einstellungen laden
    sortSelect.value   = localStorage.getItem('md-sort')   || 'added-desc';
    statusFilter.value = localStorage.getItem('md-status') || 'all';

    function allCards() { return grid ? [...grid.querySelectorAll('.item-card')] : []; }

    function clearGroupHeaders() {
      grid?.querySelectorAll('.item-group-header').forEach(el => el.remove());
    }

    function renderGrouped(visible, hidden, mode) {
      clearGroupHeaders();
      const frag = document.createDocumentFragment();
      let lastKey = null;
      visible.forEach(card => {
        let key = '';
        let label = '';
        if (mode === 'artist') {
          key = (card.dataset.artist || '').trim() || '~unknown';
          label = (card.dataset.artistName || '').trim() || 'Unbekannter Künstler';
        } else if (mode === 'title-letter') {
          const rawTitle = (card.dataset.title || '').trim();
          const firstChar = rawTitle ? rawTitle[0] : '#';
          const upper = firstChar.toLocaleUpperCase('de-DE');
          key = /[A-ZÄÖÜ0-9]/.test(upper) ? upper : '#';
          label = key;
        } else if (mode === 'year') {
          const year = String(card.dataset.year || '').trim();
          key = year && year !== '0' ? year : '~unknown-year';
          label = year && year !== '0' ? year : 'Unbekanntes Jahr';
        } else if (mode === 'rating') {
          const ratingNum = Number(card.dataset.rating || 0);
          const clamped = Number.isFinite(ratingNum) ? Math.max(0, Math.min(5, ratingNum)) : 0;
          key = String(clamped);
          label = clamped > 0 ? `${clamped} ★` : 'Unbewertet';
        }
        if (key !== lastKey) {
          const header = document.createElement('li');
          header.className = 'item-group-header';
          header.textContent = label;
          frag.appendChild(header);
          lastKey = key;
        }
        frag.appendChild(card);
      });
      grid.appendChild(frag);
      hidden.forEach(c => grid.appendChild(c));
    }

    function groupModeForSort(sort) {
      if (sort === 'artist-asc') return 'artist';
      if (sort === 'title-asc' || sort === 'title-desc') return 'title-letter';
      if (sort === 'year-asc' || sort === 'year-desc') return 'year';
      if (sort === 'rating-desc') return 'rating';
      return null;
    }

    function applyFiltersAndSort() {
      const q      = (searchInput?.value || '').toLowerCase().trim();
      const status = statusFilter.value;
      const sort   = sortSelect.value;
      const groupMode = currentView === 'carousel' ? null : groupModeForSort(sort);

      localStorage.setItem('md-sort',   sort);
      localStorage.setItem('md-status', status);

      let cards = allCards();

      // Filter
      let visibleCount = 0;
      cards.forEach(card => {
        const matchQ = !q
          || card.dataset.title.includes(q)
          || card.dataset.artist.includes(q);

        const cardStatus = card.dataset.status;
        const matchStatus = status === 'all'
          || (status === 'owned'    && cardStatus === 'owned')
          || (status === 'wishlist' && cardStatus === 'wishlist');

        const visible = matchQ && matchStatus;
        card.style.display = visible ? '' : 'none';
        if (visible) visibleCount++;
      });

      noResults && (noResults.style.display = visibleCount === 0 ? '' : 'none');
      countEl   && (countEl.textContent = visibleCount + ' Platten');

      // Sortierung: nur sichtbare Karten neu anordnen
      const visible = cards.filter(c => c.style.display !== 'none');
      visible.sort((a, b) => {
        switch (sort) {
          case 'title-asc':    return a.dataset.title.localeCompare(b.dataset.title, 'de');
          case 'title-desc':   return b.dataset.title.localeCompare(a.dataset.title, 'de');
          case 'artist-asc':   return a.dataset.artist.localeCompare(b.dataset.artist, 'de');
          case 'year-asc':     return Number(a.dataset.year)  - Number(b.dataset.year);
          case 'year-desc':    return Number(b.dataset.year)  - Number(a.dataset.year);
          case 'rating-desc':  return Number(b.dataset.rating) - Number(a.dataset.rating);
          default: /* added-desc */ return Number(b.dataset.added) - Number(a.dataset.added);
        }
      });
      const hidden = cards.filter(c => c.style.display === 'none');
      if (groupMode) renderGrouped(visible, hidden, groupMode);
      else {
        clearGroupHeaders();
        visible.forEach(c => grid.appendChild(c));
        hidden.forEach(c => grid.appendChild(c));
      }
    }

    let debounceTimer;
    searchInput?.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(applyFiltersAndSort, 150);
    });
    statusFilter?.addEventListener('change', applyFiltersAndSort);
    sortSelect?.addEventListener('change', applyFiltersAndSort);

    applyView(currentView);

    // ── Mehrfachauswahl ────────────────────────────────────────────────────
    function checkboxes() { return grid ? [...grid.querySelectorAll('.item-checkbox')] : []; }
    function selected()   { return checkboxes().filter(c => c.checked); }

    function updateBar() {
      const n = selected().length;
      bulkCount.textContent = n + ' ausgewählt';
      bulkBar.classList.toggle('visible', selectMode && n > 0);
    }

    function setSelectMode(on) {
      selectMode = on;
      document.body.classList.toggle('selection-mode', on);
      btnToggle.textContent = on ? '✕ Auswählen beenden' : '☐ Mehrere auswählen';
      if (!on) {
        checkboxes().forEach(c => { c.checked = false; c.closest('.item-card').classList.remove('selected'); });
        bulkBar.classList.remove('visible');
      }
    }

    btnToggle?.addEventListener('click', () => setSelectMode(!selectMode));

    grid?.addEventListener('click', e => {
      if (!selectMode) return;
      const card = e.target.closest('.item-card');
      if (!card) return;
      if (!e.target.closest('.item-checkbox-wrap') && !e.target.closest('.shop-link')) {
        e.preventDefault();
        const cb = card.querySelector('.item-checkbox');
        cb.checked = !cb.checked;
        card.classList.toggle('selected', cb.checked);
        updateBar();
      } else if (e.target.closest('.item-checkbox-wrap')) {
        setTimeout(() => {
          const cb = card.querySelector('.item-checkbox');
          card.classList.toggle('selected', cb.checked);
          updateBar();
        }, 0);
      }
    });

    document.getElementById('bulk-btn-all')?.addEventListener('click', () => {
      checkboxes().forEach(c => { c.checked = true; c.closest('.item-card').classList.add('selected'); });
      updateBar();
    });
    document.getElementById('bulk-btn-none')?.addEventListener('click', () => {
      checkboxes().forEach(c => { c.checked = false; c.closest('.item-card').classList.remove('selected'); });
      updateBar();
    });
    document.getElementById('bulk-btn-delete')?.addEventListener('click', () => {
      const ids = selected().map(c => c.value);
      if (!ids.length) return;
      if (!confirm(ids.length + ' Einträge wirklich löschen?')) return;
      const form = document.getElementById('bulk-delete-form');
      form.querySelectorAll('input').forEach(i => i.remove());
      ids.forEach(id => {
        const inp = document.createElement('input');
        inp.type = 'hidden'; inp.name = 'ids'; inp.value = id;
        form.appendChild(inp);
      });
      form.submit();
    });

    // ── Sterne-Bewertung (Übersicht) ──────────────────────────────────────
    document.querySelectorAll('.card-stars-interactive').forEach(widget => {
      const stars = widget.querySelectorAll('.cstar');
      let cur = Number(widget.dataset.rating);

      function render(n) {
        stars.forEach((s, i) => {
          s.classList.toggle('cstar-on',  i < n);
          s.classList.toggle('cstar-off', i >= n);
        });
      }

      stars.forEach((star, idx) => {
        star.addEventListener('mouseenter', () => render(idx + 1));
        star.addEventListener('click', async e => {
          e.stopPropagation();
          const newRating = (idx + 1 === cur) ? 0 : idx + 1;
          try {
            const resp = await fetch(`${BASE}/items/${widget.dataset.id}/rating`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ rating: newRating }),
            });
            if (resp.ok) {
              cur = newRating;
              widget.dataset.rating = newRating;
              widget.closest('.item-card').dataset.rating = newRating;
              render(cur);
            }
          } catch (err) {
            console.error('Bewertung speichern fehlgeschlagen', err);
          }
        });
      });

      widget.addEventListener('mouseleave', () => render(cur));
    });
  </script>
</body>
</html>
